{
    "ci": {
        "collect": {
            "url": [
                "http://localhost:804/",
                "http://localhost:804/coliving-partners",
                "http://localhost:804/for-companies",
                "http://localhost:804/about",
                "http://localhost:804/contact",
                "http://localhost:804/partners/pomar"
            ],
            "numberOfRuns": 1,
            "settings": {
                "preset": "desktop"
            }
        },
        "assert": {
            "assertions": {
                "categories:performance": ["warn", { "minScore": 0.85 }],
                "categories:accessibility": ["error", { "minScore": 0.95 }],
                "categories:best-practices": ["warn", { "minScore": 0.9 }],
                "categories:seo": ["error", { "minScore": 0.95 }],
                "uses-text-compression": "off",
                "uses-http2": "off"
            }
        },
        "upload": {
            "target": "filesystem",
            "outputDir": "./.lighthouseci"
        }
    }
}
